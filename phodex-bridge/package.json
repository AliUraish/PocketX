{
  "name": "rimcodex",
  "version": "1.3.7",
  "description": "Local bridge between Codex and the rimcodex mobile app. Run `rimcodex up` to start.",
  "main": "src/index.js",
  "bin": {
    "rimcodex": "./bin/rimcodex.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node ./bin/rimcodex.js up",
    "test": "node --test ./test/*.test.js",
    "prepack": "node ./scripts/prepare-private-defaults.js",
    "postpack": "node ./scripts/cleanup-private-defaults.js"
  },
  "keywords": [
    "rimcodex",
    "codex",
    "bridge",
    "cli"
  ],
  "author": "Emanuele Di Pietro",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ws": "^8.19.0"
  }
}
